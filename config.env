# Corhed Landing Page - Configurações

# ==========================================
# CONFIGURAÇÕES GERAIS
# ==========================================

# Informações da Empresa
COMPANY_NAME="Corhed"
COMPANY_EMAIL="contato@corhed.com"
COMPANY_PHONE="(11) 3000-0000"
COMPANY_ADDRESS="São Paulo, SP - Brasil"

# Cores da Marca (usadas no CSS)
PRIMARY_COLOR="#1F4E79"
ACCENT_COLOR="#C00000"
SECONDARY_COLOR="#7A7A7A"
WHITE="#FFFFFF"
BLACK="#000000"

# ==========================================
# CONFIGURAÇÕES DE DESENVOLVIMENTO
# ==========================================

# Porta do servidor de desenvolvimento
DEV_PORT=3000

# Porta do preview de produção
PREVIEW_PORT=8000

# ==========================================
# CONFIGURAÇÕES DE PRODUÇÃO
# ==========================================

# URL de produção (alterar quando fizer deploy)
PRODUCTION_URL="https://corhed.com"

# Configurações de formulário
# Substitua pela sua chave do Formspree ou outro serviço
FORMSPREE_URL=""

# Google Analytics (substitua pela sua chave)
GA_TRACKING_ID=""

# ==========================================
# ARQUIVOS IMPORTANTES
# ==========================================

# Logo (deve estar na raiz do projeto)
LOGO_FILE="corhed-logo.png"

# Arquivos principais
MAIN_FILE="index.html"
STYLES_INLINE=true  # CSS está inline no HTML

# ==========================================
# DEPLOYMENT
# ==========================================

# Opções de deploy suportadas:
# - netlify
# - vercel
# - github-pages
# - traditional (FTP/manual)

DEPLOY_METHOD="netlify"  # Escolha uma opção acima

# Configurações específicas por método
NETLIFY_SITE_ID=""
VERCEL_PROJECT_NAME=""
GITHUB_REPO="corhed/corhed-landing-page"