# Example env file for server
# Copy to server/.env and fill values if using SMTP

# Server port (optional)
PORT=3001

# CORS origin (optional, default: *)
#CORS_ORIGIN=http://localhost:3000

# Email (optional) - configure SMTP to enable email notifications
#SMTP_HOST=smtp.example.com
#SMTP_PORT=587
#SMTP_SECURE=false
#SMTP_USER=user@example.com
#SMTP_PASS=supersecret
#EMAIL_FROM="Corhed Website" <no-reply@yourdomain.com>
#CONTACT_TO=you@yourdomain.com

# Storage backend: 'sqlite' (default) or 'file'
#USE_DB=sqlite

# Rate limiting settings for contact/newsletter endpoints
#RATE_WINDOW_MS=60000
#RATE_MAX=10
